# Copy to .env.local for local development. On Vercel, add each of these
# under Project Settings → Environment Variables instead (see README.md
# "Deploying to Vercel" for exactly which environments need which keys).

# --- Clerk (Dashboard → API Keys) ---------------------------------------
# NEXT_PUBLIC_* keys are inlined into the client bundle at build time.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- MongoDB Atlas --------------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=yourApp
MONGODB_DB=urpadel

# --- App -------------------------------------------------------------------
# Default super admin email — has full access even with no AppUser record.
SUPERADMIN_EMAIL=m.ignaczak.92@gmail.com
# Canonical production URL, used for metadata (Open Graph / canonical links).
# Set to your Vercel domain, e.g. https://urpadel.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
